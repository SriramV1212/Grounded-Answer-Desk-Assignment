# Anthropic API key (also set as a GitHub Secret for CI/CD)
ANTHROPIC_API_KEY=

# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=anthropic_docs

# MCP server
MCP_SERVER_URL=http://localhost:8001

# OpenClaw gateway
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=main

# Name OpenClaw exposes our MCP server's search_kb tool as, once registered
# via `openclaw mcp add <server-name> ...` (OpenClaw prefixes tool names with
# the server name, e.g. "anthropic-docs__search_kb"). Confirm the real name
# with `openclaw mcp probe <server-name> --json` and update if different.
MCP_SEARCH_KB_TOOL_NAME=anthropic-docs__search_kb
