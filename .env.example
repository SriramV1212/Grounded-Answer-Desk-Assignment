# API key for whichever LLM provider you configure OpenClaw with (also set as a GitHub Secret for CI/CD)
LLM_API_KEY=

# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=anthropic_docs

# MCP server
MCP_SERVER_URL=http://localhost:8001

# OpenClaw gateway
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=main

# Comma-separated list of origins allowed to call POST /ask from a browser (CORS).
# Include your local frontend dev origin and your deployed frontend's real URL.
ALLOWED_ORIGINS=http://localhost:3000,https://your-project.vercel.app
